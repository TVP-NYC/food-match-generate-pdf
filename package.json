{
  "name": "food-match-generate-pdf",
  "version": "1.0.0",
  "description": "AWS Lambda to generate Shopify order summary PDFs",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "invoke": "node-lambda run --handler index.handler --event event.json --environment-variables-file .env",
    "package": "node-lambda package --handler index.handler",
    "deploy": "node-lambda deploy --handler index.handler --environment-variables-file .env"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "graphql-request": "^7.1.2",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "node-lambda": "^1.3.0"
  }
}
